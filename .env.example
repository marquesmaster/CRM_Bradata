APP_ENV=development
APP_NAME=CRM Bradata
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATABASE_URL=postgresql+psycopg2://crm:crm@localhost:5432/crm_bradata

PNCP_BASE_URL=https://pncp.gov.br
PNCP_REQUEST_TIMEOUT=30
PNCP_REQUEST_DELAY_MS=300

CNPJ_WS_BASE_URL=https://publica.cnpj.ws/cnpj
CNPJ_WS_TOKEN=
CNPJ_WS_REQUEST_DELAY_MS=1500

ICP_MIN_FATURAMENTO=120000000
ICP_CNAES_TI=6201500,6202300,6203100,6204000,6209100,6311900,6319400,6201501,6202302,6203101

SCHEDULER_ENABLED=true
PNCP_DAILY_CRON_HOUR=3
PNCP_DAILY_CRON_MINUTE=0

DEFAULT_ADMIN_EMAIL=admin@bradata.com.br
DEFAULT_ADMIN_PASSWORD=ChangeMe!2026

# IA — DeepSeek (custo baixo) ou OpenAI
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Analytics — parâmetros do dashboard /relatorios/analytics
COMMISSION_RATE_PERCENT=10
CAC_MENSAL=5000
LTV_MESES_RETENCAO=18

# Lusha — enriquecimento de contatos (telefone + email) sob demanda
LUSHA_API_KEY=
LUSHA_BASE_URL=https://api.lusha.com
LUSHA_MAX_CONTATOS_POR_EMPRESA=3
LUSHA_CARGOS_PRIORIDADE=CTO,Chief Technology Officer,Head of IT,Head of Technology,Diretor de Tecnologia,Gerente de TI,IT Manager,CIO,Contract Manager,Gerente de Contratos,Head of Procurement

# SMTP (Gmail / Google Workspace)
# 1) Ativar 2FA na conta: https://myaccount.google.com/security
# 2) Gerar App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@bradata.com.br
SMTP_PASSWORD=
SMTP_FROM_NAME=Bradata
SMTP_USE_TLS=true
SMTP_REPLY_TO=
